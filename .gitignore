# TopDownRace 项目 .gitignore
# 同时支持 Android 和 WebGL 平台

# ====================
# Unity 通用（必须）
# ====================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/.utmp/
*.log
*.pidb
*.csproj
*.sln
*.unityproj
*.userprefs

# ====================
# Android 专属
# ====================
# 安装包
*.apk
*.aab
# 密钥库（绝对不要上传！）
*.keystore
*.jks
*.override.keystore
# Gradle 临时文件
gradle-app.setting
**/bin/
**/gen/
**/obj/Debug/
**/obj/Release/

# ====================
# WebGL 专属
# ====================
# WebGL构建产物
Build/WebGL/
**/webgl-builds/
*.mem
*.data.gz
*.wasm.gz
*.framework.js.gz
*.loader.js
# Emscripten 缓存
.emscripten_cache/
.emscripten_ports/

# ====================
# 工具/系统文件
# ====================
# IDE
.vscode/
.idea/
*.user
# Mac系统
.DS_Store
# Blender自动备份
*.blend1
*.blend2
*.blend?.meta
# 内存捕获
[Mm]emoryCaptures/

# ====================
# 重要例外（需要保留的文件）
# ====================
!ProjectSettings/ProjectVersion.txt
!Packages/manifest.json
!Packages/packages-lock.json
